# 교재 GraphRAG 인덱서 환경변수 예시 (실제 값은 .env에 설정, 커밋 금지)

# --- LLM / 임베딩 ---
GROQ_API_KEY=gsk_...              # 추출·커뮤니티 요약 (Groq gpt-oss-120b)
OPENAI_API_KEY=sk-...             # 벡터 인덱스 임베딩 (text-embedding-3-large)

# --- Neo4j (전용 컨테이너 code-finder-neo4j) ---
NEO4J_URI=bolt://localhost:7690
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=codefinder
NEO4J_DATABASE=neo4j

# --- (선택) 인덱서 튜너블 override ---
# KG_TEXTBOOK_GLOB=~/workspace/aistudy/agentic-ai/textbook/*.md
# KG_EXTRACT_CONCURRENCY=5         # 비동기 추출 동시성(429 방지)
# KG_VECTOR_INDEX=true             # 벡터 인덱스 생성 여부
# KG_EMBEDDING_MODEL=text-embedding-3-large
# KG_LLM_MODEL=openai/gpt-oss-120b

# ====================================================================== #
# 통합 검색 백엔드 API (app/) 추가 키
# ====================================================================== #
# --- 멀티 LLM 합성 ---
CLAUDE_API_KEY=sk-ant-...         # Claude Sonnet 5 (코드 설명·예제 합성)
GEMINI_API_KEY=AIza...            # Gemini (요약·다국어 대안)
# --- Post 리랭킹 (변수명 주의: 올바른 철자는 COHERE) ---
COHERE_API_KEY=...                # Cohere rerank (rerank-multilingual-v3.0)
# --- 유튜브 수집 ---
YOUTUBE_API_KEY=AIza...           # YouTube Data API v3 (영상 검색)
# YT_WEBSHARE_USER=...            # (선택) 자막 IP 차단 완화용 Webshare 프록시
# YT_WEBSHARE_PASS=...

# --- (선택) 백엔드 라우팅·타임아웃 override ---
# LLM_ROUTING_MODEL=openai/gpt-oss-120b   # Groq 도구 라우팅 모델
# LLM_CODE_MODEL=claude-sonnet-5          # 코드 합성 모델
# LLM_SUMMARY_MODEL=gpt-4o-mini           # 요약 모델
# LLM_GEMINI_MODEL=gemini-2.5-flash
# RERANK_MODEL=rerank-multilingual-v3.0
# RERANK_TOP_N=8
# CHECKPOINTER=sqlite                     # sqlite(기본) | memory
# CHECKPOINT_SQLITE=app/checkpoints/search.sqlite
# FANOUT_WEB_TIMEOUT=8                     # 웹 소스 팬아웃 예산(초)
# FANOUT_YOUTUBE_TIMEOUT=15
# REACT_MAX_ITERATIONS=7                   # ReAct 반복 상한
